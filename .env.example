# 가늠터 환경변수 예시 — 이 파일을 .env로 복사하고 실제 키를 채우세요.
# 실제 .env는 .gitignore에 의해 커밋되지 않습니다. 키를 코드/커밋에 넣지 마세요.
#   cp .env.example .env

# ── LLM (ReAct 에이전트 모델) ─────────────────────────────
# OpenAI 호환 프록시 엔드포인트. 로컬/사내 게이트웨이.
LLM_BASE_URL=http://127.0.0.1:10532/v1
LLM_MODEL=gpt-5.5
# (선택) SSAFY GMS 프록시 키 — LLM_BASE_URL 미설정 시 폴백.
GMS_KEY=

# ── 지도 (프론트 카카오맵) ────────────────────────────────
# 카카오 JavaScript 키. https://developers.kakao.com 앱 등록 후 발급(도메인 제한 권장).
KAKAO_KEY=

# ── 공간정보 (VWorld) ─────────────────────────────────────
# 주소→좌표·지적·용도지역·공간레이어. https://www.vworld.kr 오픈API 인증키.
VWORLD_KEY=
VWORLD_DOMAIN=http://localhost

# ── 공공데이터 (data.go.kr) ───────────────────────────────
# 행위제한·건축물대장(건축HUB getBr*)·규제안내서. https://www.data.go.kr 활용신청 후 일반 인증키(Decoding).
DATAGO_KEY=

# ── 법령/조례 (law.go.kr) ─────────────────────────────────
# 국가법령정보 DRF OC(기관코드). https://open.law.go.kr 오픈API 신청.
LAW_OC=

# ── 기타 ──────────────────────────────────────────────────
# 컨텍스트 트리거 임계(토큰).
CTX_TRIGGER=900000
